# VibeVoyage AI — Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Supabase / PostgreSQL ───────────────────────────────
DATABASE_URL=postgresql://postgres:your_password@db.your_supabase_url.co:5432/postgres
SUPABASE_URL=https://your_supabase_url.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key
# ─── Google Gemini AI ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id
STRIPE_ANNUAL_PRICE_ID=price_your_annual_price_id

# ─── Email (Nodemailer) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=abmartofficial@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL="VibeVoyage AI <noreply@vibevoyage.ai>"

# ─── Frontend ────────────────────────────────────────────
# Local development
FRONTEND_URL=http://localhost:5173
# Production (Update this on Render dashboard)
# FRONTEND_URL=https://vibevoyage-frontend-izx99dfsy-abmartofficial-2931s-projects.vercel.app

# ─── Rate Limiting ──────────────────────────────────────
FREE_TIER_DAILY_LIMIT=5
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
